{
  "name": "AssetTrack polyglot",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-22.04",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": true,
      "dockerDashComposeVersion": "v2"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    },
    "ghcr.io/devcontainers/features/dotnet:2": {
      "version": "8.0"
    },
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.12"
    },
    "ghcr.io/devcontainers/features/java:1": {
      "version": "21",
      "installMaven": true,
      "mavenVersion": "3.9.6"
    }
  },
  "forwardPorts": [4321, 5001, 5002, 5003, 5004, 5005, 5006],
  "portsAttributes": {
    "4321": { "label": "web (Astro)" },
    "5001": { "label": "assets-svc (.NET)" },
    "5002": { "label": "workforce-svc (Java 21)" },
    "5003": { "label": "reporting-svc (Python)" },
    "5004": { "label": "notifications-svc (Python)" },
    "5005": { "label": "audit-svc (legacy Java 11)" },
    "5006": { "label": "auth-svc (legacy Java 11)" }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-azuretools.vscode-docker",
        "vscjava.vscode-java-pack",
        "ms-dotnettools.csdevkit",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "astro-build.astro-vscode",
        "bradlc.vscode-tailwindcss",
        "github.copilot",
        "github.copilot-chat"
      ]
    }
  },
  "postCreateCommand": "docker compose build --parallel || true",
  "remoteUser": "vscode"
}

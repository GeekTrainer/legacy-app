---
import Layout from "../layouts/Layout.astro";
import StatusBadge from "../components/StatusBadge.astro";
import { warrantyExpiring, utilization } from "../lib/api/reporting";

let warranty: Awaited<ReturnType<typeof warrantyExpiring>> | null = null;
let util: Awaited<ReturnType<typeof utilization>> | null = null;
let errors: string[] = [];

try { warranty = await warrantyExpiring(365); } catch (e: any) { errors.push(`warranty: ${e.message}`); }
try { util = await utilization(); }            catch (e: any) { errors.push(`utilization: ${e.message}`); }
---
<Layout title="Reports">
  <h1 class="text-2xl font-semibold mb-4">Reports</h1>
  {errors.length > 0 && (
    <div class="rounded border border-amber-200 bg-amber-50 text-amber-900 p-3 text-sm mb-4">
      <ul class="list-disc pl-5">{errors.map(e => <li>{e}</li>)}</ul>
    </div>
  )}

  {util && (
    <section class="mb-8">
      <h2 class="text-lg font-medium mb-2">Utilization</h2>
      <div class="bg-white rounded-lg shadow-sm p-4">
        <p>Total assets: <strong>{util.total}</strong> — In use: <strong>{util.in_use}</strong> ({util.utilization_pct}%)</p>
        <ul class="mt-2 flex flex-wrap gap-3">
          {Object.entries(util.by_status).map(([s, n]) => (
            <li class="flex items-center gap-2 text-sm">
              <StatusBadge status={s} />
              <span class="font-mono">{n}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  {warranty && (
    <section>
      <h2 class="text-lg font-medium mb-2">Warranty expiring (next 365 days or already expired) — {warranty.count}</h2>
      <div class="bg-white rounded-lg shadow-sm overflow-hidden">
        <table class="w-full text-sm">
          <thead class="bg-slate-100 text-slate-700">
            <tr>
              <th class="text-left px-3 py-2">Asset</th>
              <th class="text-left px-3 py-2">Model</th>
              <th class="text-left px-3 py-2">Warranty expiry</th>
              <th class="text-left px-3 py-2">Label</th>
              <th class="text-left px-3 py-2">Status</th>
            </tr>
          </thead>
          <tbody>
            {warranty.items.map(w => (
              <tr class="border-t">
                <td class="px-3 py-2 font-mono">{w.assetTag}</td>
                <td class="px-3 py-2">{w.model}</td>
                <td class="px-3 py-2">{w.warrantyExpiry}</td>
                <td class="px-3 py-2 text-slate-600">{w.label}</td>
                <td class="px-3 py-2"><StatusBadge status={w.status} /></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  )}
</Layout>

---
import Layout from "../../layouts/Layout.astro";
import { listEmployees } from "../../lib/api/workforce";

const params = Astro.url.searchParams;
const department = params.get("department") ?? "";
const onlyActive = params.get("active") === "true";

let employees = [] as Awaited<ReturnType<typeof listEmployees>>;
let error: string | null = null;

try {
  employees = await listEmployees({
    department: department || undefined,
    active: onlyActive ? true : undefined,
  });
} catch (e: any) {
  error = e.message;
}

const departments = ["Engineering", "Marketing", "Finance", "Human Resources", "Operations", "Sales"];
---
<Layout title="Employees">
  <h1 class="h3 mb-3">Employees</h1>
  <form method="get" class="card shadow-sm mb-3">
    <div class="card-body row g-3 align-items-end">
      <div class="col-md-4">
        <label class="form-label small text-secondary mb-1">Department</label>
        <select name="department" class="form-select form-select-sm">
          <option value="">All</option>
          {departments.map(d => <option value={d} selected={d === department}>{d}</option>)}
        </select>
      </div>
      <div class="col-md-3">
        <div class="form-check">
          <input class="form-check-input" type="checkbox" name="active" value="true" checked={onlyActive} id="onlyActive" />
          <label class="form-check-label" for="onlyActive">Active only</label>
        </div>
      </div>
      <div class="col-md-2">
        <button class="btn btn-dark btn-sm">Filter</button>
      </div>
    </div>
  </form>
  {error && <div class="alert alert-danger">{error}</div>}
  <div class="card shadow-sm">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Department</th>
            <th>Title</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          {employees.map(e => (
            <tr>
              <td><a class="link-dark" href={`/employees/${e.id}`}>{e.firstName} {e.lastName}</a></td>
              <td class="text-secondary">{e.email}</td>
              <td>{e.department}</td>
              <td>{e.title}</td>
              <td>
                {e.active
                  ? <span class="badge bg-success-subtle text-success-emphasis">Active</span>
                  : <span class="badge bg-secondary-subtle text-secondary-emphasis">Inactive</span>}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</Layout>

---
import Layout from "../../layouts/Layout.astro";
import StatusBadge from "../../components/StatusBadge.astro";
import { listAssets, searchAssets, type Asset } from "../../lib/api/assets";

const params = Astro.url.searchParams;
const type = params.get("type") ?? "";
const status = params.get("status") ?? "";
const q = params.get("q") ?? "";

let assets: Asset[] = [];
let error: string | null = null;

try {
  assets = (type || status || q)
    ? await searchAssets({ type, status, q })
    : await listAssets();
} catch (e: any) {
  error = e.message;
}

const allTypes = ["Laptop", "Monitor", "Keyboard", "Phone", "Keycard", "Docking Station"];
const allStatuses = ["available", "assigned", "retired", "lost"];
---
<Layout title="Assets">
  <div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="h3 mb-0">Assets</h1>
    <a href="/assets/new" class="btn btn-dark btn-sm">+ New asset</a>
  </div>

  <form method="get" class="card shadow-sm mb-3">
    <div class="card-body row g-3 align-items-end">
      <div class="col-md-3">
        <label class="form-label small text-secondary mb-1">Type</label>
        <select name="type" class="form-select form-select-sm">
          <option value="">Any</option>
          {allTypes.map(t => <option value={t} selected={t === type}>{t}</option>)}
        </select>
      </div>
      <div class="col-md-3">
        <label class="form-label small text-secondary mb-1">Status</label>
        <select name="status" class="form-select form-select-sm">
          <option value="">Any</option>
          {allStatuses.map(s => <option value={s} selected={s === status}>{s}</option>)}
        </select>
      </div>
      <div class="col-md-4">
        <label class="form-label small text-secondary mb-1">Search tag / manufacturer / model</label>
        <input type="text" name="q" value={q} class="form-control form-control-sm" />
      </div>
      <div class="col-md-2 d-flex gap-2">
        <button class="btn btn-dark btn-sm">Filter</button>
        {(type || status || q) && <a href="/assets" class="btn btn-link btn-sm text-secondary">Clear</a>}
      </div>
    </div>
  </form>

  {error && <div class="alert alert-danger">{error}</div>}

  <div class="card shadow-sm">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>Tag</th>
            <th>Type</th>
            <th>Make / Model</th>
            <th>Serial</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          {assets.map(a => (
            <tr>
              <td class="font-monospace">
                <a href={`/assets/${a.id}`} class="link-dark">{a.assetTag}</a>
              </td>
              <td>{a.assetType}</td>
              <td>{a.manufacturer} {a.model}</td>
              <td class="font-monospace small text-secondary">{a.serialNumber ?? "—"}</td>
              <td><StatusBadge status={a.status} /></td>
            </tr>
          ))}
          {assets.length === 0 && (
            <tr><td colspan="5" class="text-center text-secondary py-4">No assets match.</td></tr>
          )}
        </tbody>
      </table>
    </div>
  </div>
</Layout>

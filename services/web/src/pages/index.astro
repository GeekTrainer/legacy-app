---
import Layout from "../layouts/Layout.astro";
import StatusBadge from "../components/StatusBadge.astro";
import { statsByStatus } from "../lib/api/assets";
import { listEmployees } from "../lib/api/workforce";
import { utilization } from "../lib/api/reporting";

let assetStats: Record<string, number> = {};
let employeeCount = 0;
let activeCount = 0;
let utilizationPct = 0;
let errors: string[] = [];

try {
  assetStats = await statsByStatus();
} catch (e: any) {
  errors.push(`assets-svc: ${e.message}`);
}

try {
  const employees = await listEmployees();
  employeeCount = employees.length;
  activeCount = employees.filter(e => e.active).length;
} catch (e: any) {
  errors.push(`workforce-svc: ${e.message}`);
}

try {
  const u = await utilization();
  utilizationPct = u.utilization_pct;
} catch (e: any) {
  errors.push(`reporting-svc: ${e.message}`);
}

const totalAssets = Object.values(assetStats).reduce((a, b) => a + b, 0);
const statusOrder = ["available", "assigned", "retired", "lost"];
---
<Layout title="Dashboard">
  <h1 class="h3 mb-4">Dashboard</h1>

  {errors.length > 0 && (
    <div class="alert alert-warning">
      <p class="fw-semibold mb-1">Some backend services aren't responding:</p>
      <ul class="mb-0">
        {errors.map(e => <li>{e}</li>)}
      </ul>
    </div>
  )}

  <div class="row g-3 mb-4">
    <div class="col-sm-6 col-lg-3">
      <div class="card shadow-sm h-100">
        <div class="card-body">
          <div class="text-secondary small">Total assets</div>
          <div class="display-6 fw-semibold">{totalAssets}</div>
        </div>
      </div>
    </div>
    <div class="col-sm-6 col-lg-3">
      <div class="card shadow-sm h-100">
        <div class="card-body">
          <div class="text-secondary small">Employees</div>
          <div class="display-6 fw-semibold">{employeeCount}</div>
          <div class="text-secondary small">{activeCount} active</div>
        </div>
      </div>
    </div>
    <div class="col-sm-6 col-lg-3">
      <div class="card shadow-sm h-100">
        <div class="card-body">
          <div class="text-secondary small">Utilization</div>
          <div class="display-6 fw-semibold">{utilizationPct}%</div>
        </div>
      </div>
    </div>
    <div class="col-sm-6 col-lg-3">
      <div class="card shadow-sm h-100">
        <div class="card-body">
          <div class="text-secondary small">Lost / retired</div>
          <div class="display-6 fw-semibold">{(assetStats.lost ?? 0) + (assetStats.retired ?? 0)}</div>
        </div>
      </div>
    </div>
  </div>

  <h2 class="h5 mb-3">Assets by status</h2>
  <div class="card shadow-sm">
    <ul class="list-group list-group-flush">
      {statusOrder.filter(s => assetStats[s]).map(s => (
        <li class="list-group-item d-flex align-items-center justify-content-between">
          <StatusBadge status={s} />
          <span class="font-monospace">{assetStats[s]}</span>
        </li>
      ))}
    </ul>
  </div>
</Layout>

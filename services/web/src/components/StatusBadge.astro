---
// StatusBadge.astro — colored badge per asset status.
// INTENTIONAL BUG (course exercise #8): the colors for "retired" and "lost"
// are wrong. "retired" should be gray and "lost" should be red.
const { status } = Astro.props as { status: string };

const colorByStatus: Record<string, string> = {
  available: "bg-green-100 text-green-800",
  assigned:  "bg-blue-100 text-blue-800",
  retired:   "bg-green-100 text-green-800",   // BUG: should be gray
  lost:      "bg-blue-100 text-blue-800",     // BUG: should be red
};

const classes = colorByStatus[status] ?? "bg-slate-100 text-slate-700";
---
<span class={"inline-block rounded-full px-2 py-0.5 text-xs font-medium " + classes}>
  {status}
</span>
